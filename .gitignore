# ============================================
# PROJECT-SPECIFIC IGNORES
# ============================================

# NIH ChestX-ray dataset image folders (very large)
content/images_*/

# Generated evaluation pictures
Evaluation_pictures/

# Data directories (large files, not tracked in git)
data/raw/
data/masks/
data/processed/

# Keep data folder structure but ignore contents
!data/
!data/raw/.gitkeep
!data/masks/.gitkeep
!data/processed/.gitkeep

# Model weights and checkpoints (large binary files)
models/classifier/*.pt
models/classifier/*.pth
models/inpainting/
models/inpainting_old_v1/

# Generic model/checkpoint artifacts (avoid committing weights)
*.pt
*.pth
*.ckpt
*.onnx
*.h5
*.hdf5
*.safetensors

# CheXmask weights (large files)
models/CheXmask-Database/Weights/
models/CheXmask-Database/Outputs*/
models/CheXmask-Database/Annotations/
models/CheXmask-Database/datasets/
models/CheXmask-Database/Checkpoints/
models/CheXmask-Database/checkpoints/

# Vendored copy under src/ (should not be committed)
src/models/CheXmask-Database/

# Keep model folder structure
!models/classifier/.gitkeep
!models/inpainting/.gitkeep

# Output directories (generated)
outputs/

# Keep outputs folder structure
!outputs/.gitkeep

# Experiment tracking
wandb/

# HuggingFace cache
.cache/
~/.cache/huggingface/

# Temporary files
*.tmp
*.temp
*.bak

# Large files
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# Image files in root (keep images in proper directories)
/*.png
/*.jpg
/*.jpeg

# Notebook outputs (keep notebooks, ignore outputs)
notebooks/*.html

# Local config overrides
configs/local.yaml
configs/*.local.yaml


project.md